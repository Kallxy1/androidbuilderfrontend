# Public site URL used by sitemap/metadata
NEXT_PUBLIC_SITE_URL=https://build.xystudio.my.id

# Vercel Blob token for temporary ZIP uploads
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxx
# Optional comma-separated hosts allowed as source_url besides *.public.blob.vercel-storage.com
BLOB_ALLOWED_HOSTS=

# Fine-grained GitHub token. Required permissions:
# Actions: Read and write
# Contents: Read
GITHUB_TOKEN=github_pat_xxxxxxxxx
GITHUB_OWNER=your-github-username
GITHUB_REPO=androidengine
# Workflow filename or ID for Build Universal Project
GITHUB_WORKFLOW=build-universal.yml
GITHUB_REF=main

# Optional static admin/personal key. Keep secret.
BUILD_ACCESS_KEY=change-this-long-random-key

# Required for signed reward access keys and /key/[duration]/[claim]/[signature]
ACCESS_KEY_SECRET=change-this-very-long-random-signing-secret-min-32-chars

# Required for one-time voucher claim links in production
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxx
# Local/dev only fallback for one-time claims; do not use in production serverless
ALLOW_IN_MEMORY_CLAIMS=false

# Optional server-to-server secret for ad postback/admin issuing claim URLs via /api/access-key/claim
REWARD_CLAIM_SECRET=change-this-postback-secret
